VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional: used by username auth to build internal login emails (must match technicians.login_email)
# VITE_LOGIN_EMAIL_DOMAIN=users.jsvalve.local

# Optional local-only admin bypass (NOT for production)
VITE_ENABLE_GENERIC_ADMIN_LOGIN=false
VITE_GENERIC_ADMIN_USERNAME=localadmin
VITE_GENERIC_ADMIN_PASSWORD=change-me

# Deprecated (older builds): VITE_GENERIC_ADMIN_EMAIL
